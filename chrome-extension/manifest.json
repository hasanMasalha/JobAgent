{
  "manifest_version": 3,
  "name": "JobAgent DEV",
  "version": "1.3.0",
  "description": "Local dev build — do not submit to Chrome Web Store.",
  "permissions": [
    "cookies",
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "windows",
    "notifications"
  ],
  "host_permissions": [
    "https://jobagent.uk/*",
    "http://localhost:3000/*",
    "https://www.linkedin.com/*",
    "https://il.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jobagent.uk/*",
        "http://localhost:3000/*"
      ],
      "js": ["auth-sync.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://il.linkedin.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://jobagent.uk/*",
      "http://localhost:3000/*",
      "https://www.linkedin.com/*",
      "https://il.linkedin.com/*"
    ]
  }
}
